{
  "name": "BuffaloEdu — Lotus & Sage",
  "version": "1.0.0",
  "description": "Design tokens for BuffaloEdu (Glassmorphism + Botanical/Organic). Source of truth for colors, spacing, radii, typography, motion.",
  "colors": {
    "background": "#F8EDE3",
    "foreground": "#2D3B2A",
    "surface-0": "#EEF4EC",
    "surface-1": "#E4EDDF",
    "surface-2": "#D6E5CF",
    "muted": "#D6E5CF",
    "muted-foreground": "#6B7F69",
    "primary": "#798777",
    "primary-foreground": "#FFFFFF",
    "primary-hover": "#5E6D5C",
    "primary-subtle": "#BDD2B6",
    "border": "#C5BFB5",
    "border-focus": "#798777",
    "secondary": "#E9B96E",
    "success": "#4A9B6F",
    "warning": "#D97706",
    "danger": "#C0392B",
    "info": "#3B82A0",

    "dark.background": "#1C2419",
    "dark.foreground": "#EFF5ED",
    "dark.surface-1": "#2A3C27",
    "dark.surface-2": "#3D5439",
    "dark.primary": "#7FAD7A",
    "dark.primary-foreground": "#1C2419",
    "dark.border": "#4A6647"
  },
  "glass": {
    "glass-bg": "rgba(248,237,227,0.55)",
    "glass-bg-strong": "rgba(228,237,223,0.70)",
    "glass-border": "rgba(189,210,182,0.60)",
    "glass-shadow": "0 4px 24px rgba(121,135,119,0.18), inset 0 1px 0 rgba(255,255,255,0.45)",
    "glass-blur": "blur(12px)",
    "glass-blur-strong": "blur(20px)"
  },
  "spacing": {
    "base": 4,
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "xxl": 32,
    "huge": 48
  },
  "radii": {
    "sm": 8,
    "card": 16,
    "modal": 24,
    "full": 9999
  },
  "typography": {
    "bodyFont": "Be Vietnam Pro",
    "monoFont": "JetBrains Mono",
    "scales": {
      "hero": "text-5xl / text-6xl",
      "h1": "text-3xl",
      "h2": "text-2xl",
      "h3": "text-lg",
      "body": "text-base",
      "small": "text-xs",
      "label": "text-sm"
    }
  },
  "motion": {
    "duration-fast": "150ms",
    "duration-medium": "400ms",
    "duration-long": "600ms",
    "entrance-ease": "cubic-bezier(0.2,0.9,0.2,1)",
    "float-loop": "6s"
  },
  "accessibility": {
    "focus-ring-width": 3,
    "min-tap-size": 44,
    "contrast": "WCAG AA (4.5:1) target"
  },
  "assets": {
    "mascot": {
      "name": "mascot-bo.svg",
      "exports": ["480x480", "240x240", "48x48"],
      "layers": ["body", "hat", "ribbon", "eyes"]
    },
    "logo": {
      "name": "logo.svg",
      "exports": ["240x80", "120x40"]
    },
    "leafPattern": {
      "name": "leaf-pattern.svg",
      "tile": true
    }
  }
}
